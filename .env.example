# Server
NODE_ENV=development
PORT=4000

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/techwiki

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Cache
CACHE_MAX_ITEMS=1000
CACHE_TTL_MS=60000

# Worker pool (CPU-bound offloading)
WORKER_POOL_SIZE=4

# Geo/IP lookup for visitor tracking (free, keyless; degrades gracefully)
GEO_LOOKUP_ENABLED=true
GEO_LOOKUP_URL=http://ip-api.com/json
GEO_LOOKUP_TIMEOUT_MS=1500

# Bootstrap admin (used by seed script)
ADMIN_EMAIL=admin@techwiki.dev
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=TechWiki Admin
